{
  "metapak": {
    "configs": [
      "main",
      "readme",
      "tsesm",
      "eslint",
      "jest",
      "ghactions",
      "codeclimate"
    ],
    "data": {
      "files": "'src/**/*.ts'",
      "testsFiles": "'src/**/*.test.ts'",
      "distFiles": "'dist/**/*.js'",
      "ignore": [
        "dist"
      ],
      "bundleFiles": [
        "dist",
        "src"
      ]
    }
  },
  "name": "ease-precision-drop",
  "version": "0.0.0",
  "description": "Use ease functions to drop precision for given value intervals.",
  "keywords": [
    "precision",
    "ease",
    "iot",
    "drop"
  ],
  "license": "MIT",
  "author": {
    "name": "Nicolas Froidure",
    "email": "nicolas.froidure@insertafter.com",
    "url": "https://insertafter.com/en/index.html"
  },
  "type": "module",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nfroidure/ease-precision-drop.git"
  },
  "dependencies": {
    "yerror": "^11.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.39",
    "conventional-changelog": "^7.2.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.4.2",
    "metapak": "7.1.1",
    "metapak-nfroidure": "22.1.3",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "scripts": {
    "build": "rimraf 'dist' && tsc --outDir dist",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s && git add CHANGELOG.md",
    "cli": "env NODE_ENV=${NODE_ENV:-cli}",
    "commitlint": "commitlint",
    "cover": "node --run jest -- --coverage",
    "format": "node --run prettier",
    "jest": "NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest",
    "lint": "eslint 'src/**/*.ts'",
    "metapak": "metapak",
    "precommit": "node --run test && node --run lint && node --run build && node --run architecture && node --run metapak -- -s",
    "prettier": "prettier --write 'src/**/*.ts'",
    "preversion": "node --run test && node --run lint && node --run build && node --run architecture && node --run metapak -- -s",
    "rebuild": "swc ./src -s -d dist -C jsc.target=es2022",
    "test": "node --run jest",
    "version": "node --run changelog"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/nfroidure"
  },
  "contributors": [],
  "engines": {
    "node": ">=24.14.0"
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "bugs": {
    "url": "https://github.com/nfroidure/ease-precision-drop/issues"
  },
  "homepage": "https://github.com/nfroidure/ease-precision-drop#readme",
  "types": "dist/index.d.ts",
  "prettier": {
    "semi": true,
    "printWidth": 80,
    "singleQuote": true,
    "trailingComma": "all",
    "proseWrap": "always"
  },
  "overrides": {
    "typescript-eslint": {
      "typescript": "^6"
    },
    "@typescript-eslint/eslint-plugin": {
      "typescript": "^6"
    },
    "@typescript-eslint/parser": {
      "typescript": "^6"
    }
  },
  "jest": {
    "coverageReporters": [
      "lcov"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "roots": [
      "<rootDir>/src"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "@swc/jest",
        {}
      ]
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "(.+)\\.js": "$1"
    },
    "extensionsToTreatAsEsm": [
      ".ts"
    ]
  }
}